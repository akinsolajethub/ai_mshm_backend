# ─────────────────────────────────────────────────────────────────────────────
#  AI-MSHM  –  Environment Variables (Development)
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.ykfntcfrfghrmjrdtfix:NA-e2y-KwYnf%40vw@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="rediss://default:gQAAAAAAARX4AAIncDIyYTUxODgxMmZiMjk0ZGU4YWJhMTAyNzExNjA@ready-seasnail-71160.upstash.io:6379?ssl_cert_reqs=CERT_NONE"

# ── Free Tier Mode (IMPORTANT) ────────────────────────────────────────────────
# If TRUE:
# - No Redis needed
# - No Celery worker needed
# - Tasks run synchronously
FREE_TIER=True

# ── Channels (WebSockets) ─────────────────────────────────────────────────────
# If TRUE → no Redis needed for WebSockets
USE_IN_MEMORY_CHANNELS=True

# ── Cloudinary (REQUIRED for media uploads) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
DEFAULT_FROM_EMAIL=AI-MSHM <noreply@yourdomain.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://awhares.vercel.app

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173