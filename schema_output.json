        Use this to populate the rPPG prediction trend charts.
      summary: Get rPPG prediction history
      tags:
      - rPPG
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/rppg/session:
    post:
      operationId: api_v1_rppg_session_create
      description: |-
        Log an rPPG (HRV) session.
        Proxied to: POST /api/v1/rppg/session on Node.js

        Call this after the user completes an rPPG measurement session.
      summary: Log an rPPG (HRV) session
      tags:
      - rPPG
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/RppgSessionRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/RppgSessionRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/RppgSessionRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RppgSession'
