        breast_right_vas:
          type: number
          format: double
          maximum: 10.0
          minimum: 0.0
          nullable: true
        mastalgia_side:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/MastalgiaSideEnum'
          - $ref: '#/components/schemas/BlankEnum'
          - $ref: '#/components/schemas/NullEnum'
        mastalgia_quality:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/MastalgiaQualityEnum'
          - $ref: '#/components/schemas/BlankEnum'
