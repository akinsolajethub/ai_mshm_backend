        all predictions.'
      summary: Get unified PCOS risk score
      tags:
      - Predictions
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/predictions/trigger/:
    post:
      operationId: api_v1_predictions_trigger_create
      description: Forces a prediction run for today's summary regardless of completeness.
        Resets prediction_run flag and re-queues the ML pipeline. Use this during
        development to test predictions without waiting for both morning and evening
        sessions to complete.
      summary: Manually trigger prediction (dev/testing)
      tags:
      - Predictions
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
