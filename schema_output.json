        mean_eda:
          type: number
          format: double
          maximum: 20
          minimum: 0
          description: Mean electrodermal activity in µS (0–20)
        asi:
          type: number
          format: double
          maximum: 2
          minimum: 0
          nullable: true
          description: Autonomic Stress Index (0–1.58). Optional.
        session_type:
          allOf:
