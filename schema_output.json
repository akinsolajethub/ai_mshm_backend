      description: Returns the most recently submitted Modified Ferriman-Gallwey assessment
        for this user.
      summary: Get latest mFG hirsutism score
      tags:
      - Check-in
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_checkin_mfg_create
      description: 'Weekly assessment of hair growth across 9 body areas (upper lip,
        chin, chest, upper back, lower back, upper abdomen, lower abdomen, upper arm,
        thigh) each scored 0–4. Total mFG score (max 36) is auto-computed. Score feeds
        into Hirsutism_mFG_Score in the ML model. Interpretation: 0–7 Normal, 8–16
        Mild, 17–24 Moderate, 25+ Severe.'
      summary: Submit weekly mFG hirsutism assessment
      tags:
      - Check-in
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/HirsutismMFGRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/HirsutismMFGRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/HirsutismMFGRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/checkin/morning/{session_id}/:
    get:
      operationId: api_v1_checkin_morning_retrieve
      description: Returns previously saved fatigue, pelvic pressure, and PSQ-3 hyperalgesia
        values for this session.
      summary: Get saved morning check-in data
      parameters:
      - in: path
        name: session_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Check-in
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_checkin_morning_create
      description: Saves fatigue VAS (0–10), pelvic pressure VAS (0–10), and the three
        PSQ-3 hyperalgesia sliders (skin sensitivity, muscle pressure pain, body tenderness
        — each 0–10). The hyperalgesia index is auto-computed as the mean of the three
        PSQ-3 values and stored as Painful_Touch_VAS for the ML model. Call /session/<id>/submit/
        after this to complete.
      summary: Save morning check-in data
      parameters:
      - in: path
        name: session_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Check-in
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/MorningCheckinRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/MorningCheckinRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/MorningCheckinRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
