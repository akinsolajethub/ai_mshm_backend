      - Predictions
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/predictions/latest/:
    get:
      operationId: api_v1_predictions_latest_retrieve
      description: 'Returns the most recent ML prediction result for the authenticated
        patient. Each result contains scores, flags, severity, and risk probability
        for 6 conditions: Infertility, Dysmenorrhea, PMDD, Type 2 Diabetes, Cardiovascular
        Disease, and Endometrial Cancer. Returns null with a prompt message if fewer
        than 3 days of check-in data exist.'
