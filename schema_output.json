components:
  schemas:
    BlankEnum:
      enum:
      - ''
    ChangePasswordRequest:
      type: object
      description: |-
        Allows an authenticated user to change their password.
        If user must_change_password=True, old_password is not required (temp password scenario).
      properties:
        old_password:
          type: string
        new_password:
          type: string
          minLength: 8
      required:
      - new_password
    ClinicianOnboardingRequest:
      type: object
      description: Clinician onboarding - sets specialization and downstream expertise.
      properties:
        specialization:
          $ref: '#/components/schemas/SpecializationEnum'
        downstream_expertise:
          type: array
          items:
            $ref: '#/components/schemas/DownstreamExpertiseEnum'
          maxItems: 10
          minItems: 1
        license_number:
          type: string
          maxLength: 50
        years_of_experience:
          type: integer
          minimum: 0
          default: 0
        bio:
          type: string
      required:
      - downstream_expertise
      - specialization
    ConditionConfirmedEnum:
      enum:
      - pcos_confirmed
      - hormonal_imbalance
      - metabolic_syndrome
      - multiple
      - none_confirmed
      type: string
      description: |-
        * `pcos_confirmed` - pcos_confirmed
        * `hormonal_imbalance` - hormonal_imbalance
        * `metabolic_syndrome` - metabolic_syndrome
        * `multiple` - multiple
        * `none_confirmed` - none_confirmed
    ConditionEnum:
      enum:
      - pcos
      - maternal
      - cardiovascular
      type: string
      description: |-
        * `pcos` - PCOS
        * `maternal` - Maternal Health
        * `cardiovascular` - Cardiovascular
    ConfirmPasswordRequest:
      type: object
      description: |-
        Requires the user's current password before performing a destructive action
        (e.g. account deletion). Used as a final confirmation step.
      properties:
        password:
          type: string
          minLength: 1
          description: Current password to confirm the action.
      required:
      - password
    ConnectDeviceRequest:
      type: object
      description: Used when connecting a new device.
      properties:
        device_type:
          $ref: '#/components/schemas/DeviceTypeEnum'
        device_name:
          type: string
          maxLength: 100
        sync_frequency:
          $ref: '#/components/schemas/SyncFrequencyEnum'
        background_sync:
          type: boolean
      required:
      - device_type
    CreateClinicianRequest:
      type: object
      description: Used by FHC Admin to create clinician accounts.
      properties:
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        email:
          type: string
          format: email
          minLength: 1
        specialization:
          allOf:
          - $ref: '#/components/schemas/SpecializationEnum'
          default: general_practice
        license_number:
          type: string
          maxLength: 50
        years_of_experience:
          type: integer
          minimum: 0
          default: 0
        bio:
          type: string
      required:
      - email
      - full_name
    CreateFHCStaffRequest:
      type: object
      description: Used by FHC Admin to create FMC staff accounts.
      properties:
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        email:
          type: string
          format: email
          minLength: 1
        staff_role:
          $ref: '#/components/schemas/CreateFHCStaffStaffRoleEnum'
        employee_id:
          type: string
          maxLength: 50
      required:
      - email
      - full_name
      - staff_role
    CreateFHCStaffStaffRoleEnum:
      enum:
      - coordinator
      - triage
      - records
      - other
      type: string
      description: |-
        * `coordinator` - Case Coordinator
        * `triage` - Triage Officer
        * `records` - Records Officer
        * `other` - Other
    CreateHCCStaffRequest:
      type: object
      description: Used by HCC Admin to create PHC staff accounts.
      properties:
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        email:
          type: string
          format: email
          minLength: 1
        staff_role:
          $ref: '#/components/schemas/StaffRole6b7Enum'
        employee_id:
          type: string
          maxLength: 50
      required:
      - email
      - full_name
      - staff_role
    CustomTokenObtainPairRequest:
      type: object
      description: |-
        Extends the default JWT token with user metadata embedded in the payload.

        Token claims added:
          - email    : user's email address
          - role     : user's role (used by frontend to route to correct portal)
          - name     : user's full name
          - unique_id: user's unique ID (MDC/YYYY/NNNNNN format)

        Login accepts either email or unique_id (e.g., MDC/2024/001234).
      properties:
        email:
          type: string
          writeOnly: true
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - email
      - password
    CyclePhaseEnum:
      enum:
      - Menstrual
      - Follicular
      - Ovulatory
      - Luteal
      type: string
      description: |-
        * `Menstrual` - Menstrual
        * `Follicular` - Follicular
        * `Ovulatory` - Ovulatory
        * `Luteal` - Luteal
    CycleRegularityEnum:
      enum:
      - regular
      - irregular
      type: string
      description: |-
        * `regular` - Regular
        * `irregular` - Irregular
    DeviceTypeEnum:
      enum:
      - apple_watch
      - fitbit
      - garmin
      - oura_ring
      - whoop
      type: string
      description: |-
        * `apple_watch` - Apple Watch
        * `fitbit` - Fitbit
        * `garmin` - Garmin
        * `oura_ring` - Oura Ring
        * `whoop` - WHOOP
    DiagnosticBasisEnum:
      enum:
      - clinical_criteria
      - lab_results
      - imaging
      - combined
      type: string
      description: |-
        * `clinical_criteria` - clinical_criteria
        * `lab_results` - lab_results
        * `imaging` - imaging
        * `combined` - combined
    DiseaseNameEnum:
      enum:
      - PCOS
      - CVD
      - T2D
      - Infertility
      - Dysmenorrhea
      - Metabolic
      - MentalHealth
      - Stroke
      - Endometrial
      type: string
      description: |-
        * `PCOS` - PCOS
        * `CVD` - Cardiovascular Disease
        * `T2D` - Type 2 Diabetes
        * `Infertility` - Infertility
        * `Dysmenorrhea` - Dysmenorrhea
        * `Metabolic` - Metabolic Syndrome
        * `MentalHealth` - Mental Health
        * `Stroke` - Stroke Risk
        * `Endometrial` - Endometrial Cancer
    DownstreamExpertiseEnum:
      enum:
      - type2_diabetes
      - cardiovascular_disease
      - obesity
      - infertility
      - endometrial_hyperplasia
      - fatty_liver
      - sleep_apnea
      - pregnancy_complications
      - mental_health
      - dermatologic
      type: string
      description: |-
        * `type2_diabetes` - type2_diabetes
        * `cardiovascular_disease` - cardiovascular_disease
        * `obesity` - obesity
        * `infertility` - infertility
        * `endometrial_hyperplasia` - endometrial_hyperplasia
        * `fatty_liver` - fatty_liver
        * `sleep_apnea` - sleep_apnea
        * `pregnancy_complications` - pregnancy_complications
        * `mental_health` - mental_health
        * `dermatologic` - dermatologic
    EmailVerificationRequest:
      type: object
      description: Accepts the raw verification token from the email link.
      properties:
        token:
          type: string
          minLength: 1
      required:
      - token
    EnsembleWeightConfig:
      type: object
      description: |-
        Serializer for EnsembleWeightConfig.
        Allows admin to view and update ensemble weights per disease.
      properties:
        id:
          type: integer
          readOnly: true
        disease_name:
          allOf:
          - $ref: '#/components/schemas/DiseaseNameEnum'
          description: |-
            Disease this weight configuration applies to

            * `PCOS` - PCOS
            * `CVD` - Cardiovascular Disease
            * `T2D` - Type 2 Diabetes
            * `Infertility` - Infertility
            * `Dysmenorrhea` - Dysmenorrhea
            * `Metabolic` - Metabolic Syndrome
            * `MentalHealth` - Mental Health
            * `Stroke` - Stroke Risk
            * `Endometrial` - Endometrial Cancer
        symptom_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Symptom Intensity model (0.0-1.0)
        menstrual_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Menstrual model (0.0-1.0)
        rppg_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for rPPG/HRV model (0.0-1.0)
        mood_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Mood model (0.0-1.0)
        rotterdam_2_criteria_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when 2 Rotterdam criteria are met (+0.05 default)
        rotterdam_3_criteria_boost:
          type: number
          format: double
          maximum: 0.3
          minimum: 0.0
          description: Boost when all 3 Rotterdam criteria are met (+0.10 default)
        metabolic_reproductive_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when metabolic + reproductive both high (+0.05 default)
        mood_rppg_stress_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when mood + rPPG stress both moderate+ (+0.03 default)
        is_active:
          type: boolean
          description: Whether this configuration is currently active
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - disease_name
      - id
      - updated_at
    EnsembleWeightConfigRequest:
      type: object
      description: |-
        Serializer for EnsembleWeightConfig.
        Allows admin to view and update ensemble weights per disease.
      properties:
        disease_name:
          allOf:
          - $ref: '#/components/schemas/DiseaseNameEnum'
          description: |-
            Disease this weight configuration applies to

            * `PCOS` - PCOS
            * `CVD` - Cardiovascular Disease
            * `T2D` - Type 2 Diabetes
            * `Infertility` - Infertility
            * `Dysmenorrhea` - Dysmenorrhea
            * `Metabolic` - Metabolic Syndrome
            * `MentalHealth` - Mental Health
            * `Stroke` - Stroke Risk
            * `Endometrial` - Endometrial Cancer
        symptom_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Symptom Intensity model (0.0-1.0)
        menstrual_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Menstrual model (0.0-1.0)
        rppg_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for rPPG/HRV model (0.0-1.0)
        mood_weight:
          type: number
          format: double
          maximum: 1.0
          minimum: 0.0
          description: Weight for Mood model (0.0-1.0)
        rotterdam_2_criteria_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when 2 Rotterdam criteria are met (+0.05 default)
        rotterdam_3_criteria_boost:
          type: number
          format: double
          maximum: 0.3
          minimum: 0.0
          description: Boost when all 3 Rotterdam criteria are met (+0.10 default)
        metabolic_reproductive_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when metabolic + reproductive both high (+0.05 default)
        mood_rppg_stress_boost:
          type: number
          format: double
          maximum: 0.2
          minimum: 0.0
          description: Boost when mood + rPPG stress both moderate+ (+0.03 default)
        is_active:
          type: boolean
          description: Whether this configuration is currently active
      required:
      - disease_name
    EthnicityEnum:
      enum:
      - white
      - black
      - hispanic
      - asian
      - south_asian
      - middle_eastern
      - mixed
      - prefer_not
      type: string
      description: |-
        * `white` - White/Caucasian
        * `black` - Black/African American
        * `hispanic` - Hispanic/Latino
        * `asian` - Asian
        * `south_asian` - South Asian
        * `middle_eastern` - Middle Eastern
        * `mixed` - Mixed/Other
        * `prefer_not` - Prefer not to say
    EveningCheckinRequest:
      type: object
      description: |-
        Mirrors EveningCheckinScreen exactly.
        Computed: breast_pain_avg, cyclic_mastalgia_score, breast_soreness_vas,
                  mastalgia_severity, gags_score, acne_severity_likert, acne_severity_label.
      properties:
        breast_left_vas:
          type: number
          format: double
          maximum: 10.0
          minimum: 0.0
