      - Predictions
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/predictions/pcos/:
    get:
      operationId: api_v1_predictions_pcos_retrieve
      description: 'Returns a combined PCOS risk score from all 4 models: Symptom
