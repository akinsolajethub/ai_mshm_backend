          type: integer
          maximum: 4
          minimum: 0
        acne_right_cheek:
          type: integer
          maximum: 4
          minimum: 0
        acne_left_cheek:
          type: integer
          maximum: 4
          minimum: 0
        acne_nose:
          type: integer
          maximum: 4
          minimum: 0
        acne_chin:
          type: integer
          maximum: 4
          minimum: 0
        acne_chest_back:
          type: integer
          maximum: 4
          minimum: 0
        bloating_delta_cm:
          type: number
          format: double
          nullable: true
          description: Abdominal circumference Δ in cm
        unusual_bleeding:
          type: boolean
          description: Any bleeding outside period window
    FMCDiagnosticsRequestRequest:
      type: object
