openapi: 3.0.3
info:
  title: AI-MSHM API
  version: 1.0.0
  description: AI-Driven Multi-Source Health Measurement System – REST API
paths:
  /:
    get:
      operationId: root_retrieve
      summary: API root
      tags:
      - System
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/auth/forgot-password/:
    post:
      operationId: api_v1_auth_forgot_password_create
      summary: Request password reset email
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ForgotPasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ForgotPasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ForgotPasswordRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/auth/login/:
    post:
      operationId: api_v1_auth_login_create
      description: Custom login view that wraps SimpleJWT with rate limiting and proper
        response format.
      summary: Login – obtain JWT token pair
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
        required: true
      responses:
        '200':
          description: No response body
  /api/v1/auth/logout/:
    post:
      operationId: api_v1_auth_logout_create
      summary: Logout – blacklist refresh token
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LogoutRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/logs/:
    get:
      operationId: api_v1_auth_logs_retrieve
      summary: Get activity logs
      tags:
      - Admin
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/me/:
    get:
      operationId: api_v1_auth_me_retrieve
      summary: Get current user profile
      tags:
      - Auth
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_auth_me_partial_update
      description: |-
        Send as `multipart/form-data` (not JSON) when uploading an avatar.

        - `full_name` — string (optional)
        - `avatar` — image file (optional, uploads to Cloudinary)
      summary: Update current user profile (name, avatar)
      tags:
      - Auth
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUpdateProfileRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/me/change-password/:
    post:
      operationId: api_v1_auth_me_change_password_create
      summary: Change password (authenticated)
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/me/delete/:
    post:
      operationId: api_v1_auth_me_delete_create
      description: Permanently deletes the authenticated user's account and all associated
        data. Requires current password confirmation. This action is irreversible.
      summary: Delete account
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ConfirmPasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ConfirmPasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ConfirmPasswordRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/register/:
    post:
      operationId: api_v1_auth_register_create
      description: Creates a Patient or Clinician account and sends an email verification
        link.
      summary: Register a new user
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/RegisterRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/RegisterRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/RegisterRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/auth/resend-verification/:
    post:
      operationId: api_v1_auth_resend_verification_create
      summary: Resend email verification link
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ResendVerificationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ResendVerificationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ResendVerificationRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/auth/reset-password/:
    post:
      operationId: api_v1_auth_reset_password_create
      summary: Reset password with token
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ResetPasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ResetPasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ResetPasswordRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/auth/stats/:
    get:
      operationId: api_v1_auth_stats_retrieve
      summary: Get system statistics
      tags:
      - Admin
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/token/refresh/:
    post:
      operationId: api_v1_auth_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      summary: Refresh access token
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/v1/auth/users/:
    get:
      operationId: api_v1_auth_users_retrieve
      summary: List all users
      tags:
      - Admin
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_auth_users_create
      description: Create a new user account with a specified role.
      summary: Create a new user
      tags:
      - Admin
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  format: email
                full_name:
                  type: string
                password:
                  type: string
                  minLength: 8
                confirm_password:
                  type: string
                role:
                  type: string
                is_email_verified:
                  type: boolean
              required:
              - email
              - full_name
              - password
              - confirm_password
              - role
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/users/{user_id}/:
    get:
      operationId: api_v1_auth_users_retrieve_2
      summary: Get user by ID
      parameters:
      - in: path
        name: user_id
        schema:
          type: string
        required: true
      tags:
      - Admin
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/verify-email/:
    post:
      operationId: api_v1_auth_verify_email_create
      summary: Verify email address
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/EmailVerificationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/EmailVerificationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/EmailVerificationRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/v1/centers/admin/centers/:
    get:
      operationId: api_v1_centers_admin_centers_retrieve
      summary: '[Platform Admin] List ALL centers (PHC, FMC, etc)'
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_admin_centers_create
      description: Create a new facility of any type (PHC, FMC, STH, etc.)
      summary: '[Platform Admin] Create a new facility'
      tags:
      - Platform Admin — Centers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/HealthCareCenterRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/HealthCareCenterRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/HealthCareCenterRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/admin/centers/{id}/:
    get:
      operationId: api_v1_centers_admin_centers_retrieve_2
      summary: '[Platform Admin] Get facility detail'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_admin_centers_partial_update
      description: Update facility details. Use admin_email to assign an existing
        user as admin.
      summary: '[Platform Admin] Update facility'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/admin/fmc/:
    get:
      operationId: api_v1_centers_admin_fmc_retrieve
      summary: '[Platform Admin] List all FMCs'
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_admin_fmc_create
      summary: '[Platform Admin] Create an FMC'
      tags:
      - Platform Admin — Centers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/FederalHealthCenterRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/FederalHealthCenterRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/FederalHealthCenterRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/admin/fmc/{id}/:
    get:
      operationId: api_v1_centers_admin_fmc_retrieve_2
      summary: '[Platform Admin] Get FMC detail'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_admin_fmc_partial_update
      summary: '[Platform Admin] Update FMC'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedFederalHealthCenterRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedFederalHealthCenterRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedFederalHealthCenterRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    delete:
      operationId: api_v1_centers_admin_fmc_destroy
      summary: '[Platform Admin] Delete FMC'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/centers/admin/phc/:
    get:
      operationId: api_v1_centers_admin_phc_retrieve
      summary: '[Platform Admin] List all PHCs'
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/admin/phc/{id}/:
    get:
      operationId: api_v1_centers_admin_phc_retrieve_2
      summary: '[Platform Admin] Get PHC detail'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_admin_phc_partial_update
      description: Platform Admin can set escalates_to to link this PHC to an FMC.
      summary: '[Platform Admin] Update PHC'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedHealthCareCenterRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedHealthCareCenterRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedHealthCareCenterRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    delete:
      operationId: api_v1_centers_admin_phc_destroy
      summary: '[Platform Admin] Delete PHC'
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Platform Admin — Centers
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/centers/change-request/:
    get:
      operationId: api_v1_centers_change_request_retrieve
      summary: List own change requests
      tags:
      - Patient Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_change_request_create
      description: |-
        Submit a request to change your home PHC or report an issue.

        **CHANGE_PHC:** Include `requested_hcc` UUID.
        **REPORT_ISSUE / OTHER:** Just include `description`.
      summary: Submit a change request
      tags:
      - Patient Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/change-request/{id}/:
    get:
      operationId: api_v1_centers_change_request_retrieve_2
      summary: Get change request detail
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Patient Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/analytics/:
    get:
      operationId: api_v1_centers_clinician_analytics_retrieve
      summary: Get clinician analytics (CL7)
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/appointment/{patient_id}/:
    post:
      operationId: api_v1_centers_clinician_appointment_create
      summary: Book patient appointment (CL6)
      parameters:
      - in: path
        name: patient_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/cases/:
    get:
      operationId: api_v1_centers_clinician_cases_retrieve
      description: |-
        Returns all cases assigned to the authenticated clinician.

        **Filters:** `?status=assigned` | `?condition=pcos`

        Default: returns all non-discharged cases sorted by severity.
      summary: List clinician's assigned patient cases (CL2)
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/cases/{id}/:
    get:
      operationId: api_v1_centers_clinician_cases_retrieve_2
      description: |-
        GET /api/v1/centers/clinician/cases/<uuid:pk>/
        Clinician views full detail of one of their assigned cases (screen CL3).
      summary: Get assigned patient case detail (CL3)
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/communications/:
    get:
      operationId: api_v1_centers_clinician_communications_retrieve
      summary: List notifications/conversations
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_clinician_communications_create
      summary: Archive conversation
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_clinician_communications_partial_update
      summary: Mark conversation as read
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    delete:
      operationId: api_v1_centers_clinician_communications_destroy
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/centers/clinician/communications/{id}/archive/:
    get:
      operationId: api_v1_centers_clinician_communications_archive_retrieve
      summary: List notifications/conversations
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_clinician_communications_archive_create
      summary: Archive conversation
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_clinician_communications_archive_partial_update
      summary: Mark conversation as read
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    delete:
      operationId: api_v1_centers_clinician_communications_archive_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/centers/clinician/communications/{id}/read/:
    get:
      operationId: api_v1_centers_clinician_communications_read_retrieve
      summary: List notifications/conversations
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    post:
      operationId: api_v1_centers_clinician_communications_read_create
      summary: Archive conversation
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    patch:
      operationId: api_v1_centers_clinician_communications_read_partial_update
      summary: Mark conversation as read
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
    delete:
      operationId: api_v1_centers_clinician_communications_read_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/v1/centers/clinician/letter/{patient_id}/:
    post:
      operationId: api_v1_centers_clinician_letter_create
      summary: Generate clinical letter (CL6)
      parameters:
      - in: path
        name: patient_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/message/{patient_id}/:
    post:
      operationId: api_v1_centers_clinician_message_create
      summary: Send patient message (CL6)
      parameters:
      - in: path
        name: patient_id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Clinician Portal
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/centers/clinician/onboarding/:
    post:
      operationId: api_v1_centers_clinician_onboarding_create
      summary: Complete clinician onboarding
      tags:
      - Clinician Portal
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ClinicianOnboardingRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ClinicianOnboardingRequest'
